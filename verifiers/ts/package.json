{
  "name": "attest-verifier",
  "version": "0.1.2",
  "description": "Independent TypeScript verifier for attest v0.1 receipts (verifier-only).",
  "license": "Apache-2.0",
  "author": "Samuele Martinalli",
  "homepage": "https://svm-98.github.io/attest/",
  "repository": { "type": "git", "url": "git+https://github.com/SVM-98/attest.git", "directory": "verifiers/ts" },
  "bugs": { "url": "https://github.com/SVM-98/attest/issues" },
  "keywords": ["receipts", "ed25519", "verifier", "digital-purchases", "offline-verification"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "engines": { "node": ">=20.19.0" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "~0.6.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  }
}
